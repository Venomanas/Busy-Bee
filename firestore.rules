rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if true;
      allow create: if isMe(uid);
      allow update: if isMe(uid);
      allow delete: if false;
    }

    match /usernames/{username} {
      allow read: if true;
      // Username reservation: only the authenticated uid can claim/refresh their mapping
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      // Allow author to edit their post text; allow anyone signed-in to update counters only.
      allow update: if (
        signedIn() &&
        (
          resource.data.authorUid == request.auth.uid ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['likesCount', 'commentsCount', 'updatedAt'])
        )
      );
      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;

      match /likes/{uid} {
        allow read: if true;
        allow create, delete: if isMe(uid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /follows/{uid} {
      match /following/{targetUid} {
        allow read: if true;
        allow create, delete: if isMe(uid);
      }
      match /followers/{sourceUid} {
        allow read: if true;
        // Source user writes their follower-edge doc under the target uid.
        allow create, delete: if isMe(sourceUid);
      }
    }

    match /bookmarks/{uid}/items/{postId} {
      allow read, create, delete: if isMe(uid);
      allow update: if false;
    }

    match /deviceTokens/{uid}/tokens/{tokenId} {
      allow read, write: if isMe(uid);
    }

    match /notifications/{uid}/items/{notificationId} {
      allow read: if isMe(uid);
      allow write: if false; // Functions/Admin only
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberUids;
      allow update: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
        allow create: if signedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
        // Allow marking readBy.{uid}
        allow update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberUids;
        allow delete: if false;
      }
    }

    match /reports/{reportId} {
      allow create: if signedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

